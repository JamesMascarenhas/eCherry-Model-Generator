within {{ within_model }};
{% set UI = import_alias ~ ".Data.UserInput." ~ user_input_record_name %}
model {{ name }}
  import {{ import_alias }} = {{ import_target }};
  extends Modelica.Icons.Example;

  parameter Real Ufixed = {{ voltage | monum }};

{% if is_ammonia %}
  // ── Electrical ──────────────────────────────────────────────────────────────
  {{ fqn_ground }} Ground;
  {{ fqn_voltage_source }} Source(
    Ufixed = Ufixed,
    GeoRec = {{ UI }}.GeoRec);

  // ── Anode (planar) ──────────────────────────────────────────────────────────
  {{ fqn_electrode }} Anode(
    specRec   = {{ UI }}.AESspec,
    GeoRec    = {{ UI }}.GeoRec,
    CondRec   = {{ UI }}.CondRec,
    reac      = {{ "{" + UI + ".OERdummy}" }},
    CathodeEl = false,
    redeclare model ActivationOverpotentialModel = {{ fqn_activation_overpotential }},
    redeclare model TemperatureModel = Properties.TemperatureModels.TemperatureConstant);

  // ── Cathode (gas diffusion electrode) ───────────────────────────────────────
  {{ fqn_gde }} GasDiffusionCathode(
    specRec     = {{ UI }}.AESspec,
    GeoRec      = {{ UI }}.GeoRecElec,
    CondRec     = {{ UI }}.CondRec,
    reac        = {{ "{" + UI + ".HERdummy, " + UI + ".NRRdummy}" }},
    CathodeEl   = true,
    splitFactor = 0,
    redeclare model ActivationOverpotentialModel = {{ fqn_activation_overpotential }},
    redeclare model TemperatureModel = Properties.TemperatureModels.TemperatureConstant);

  // ── Electrolyte compartments ─────────────────────────────────────────────────
  {{ fqn_electrolyte }} Anolyte(
    specRec = {{ UI }}.AESspec,
    GeoRec  = {{ UI }}.GeoRecElec,
    CondRec = {{ UI }}.CondRec,
    c0      = {{ UI }}.c0_Electrolyte,
    redeclare model TemperatureModel = Properties.TemperatureModels.TemperatureConstant);

  {{ fqn_electrolyte }} Catholyte(
    specRec = {{ UI }}.AESspec,
    GeoRec  = {{ UI }}.GeoRecElec,
    CondRec = {{ UI }}.CondRec,
    c0      = {{ UI }}.c0_Electrolyte,
    redeclare model TemperatureModel = Properties.TemperatureModels.TemperatureConstant);

  // ── Separator ────────────────────────────────────────────────────────────────
  {{ fqn_separator }} Diaphragm(
    specRec = {{ UI }}.AESspec,
    GeoRec  = {{ UI }}.GeoRecMem,
    CondRec = {{ UI }}.CondRec,
    X       = {{ geo_X_membrane | monum }},
    kappa   = {{ diaphragm_kappa | monum }},
    redeclare model TemperatureModel = Properties.TemperatureModels.TemperatureConstant);

  // ── Gas channel compartment ──────────────────────────────────────────────────
  {{ fqn_gas_channel_compartment }} GasChannel(
    specRec       = {{ UI }}.AESspec,
    GeoRec        = {{ UI }}.GeoRec,
    CondRec       = {{ UI }}.CondRec,
    mol_vec_frac0 = {{ UI }}.mol_vec_frac0);

  // ── Liquid inflows ───────────────────────────────────────────────────────────
  {{ fqn_liquid_inflow }} InflowAnolyte(
    specRec = {{ UI }}.AESspec,
    GeoRec  = {{ UI }}.GeoRecElec,
    CondRec = {{ UI }}.CondRec,
    c0      = {{ UI }}.c0_Electrolyte,
    t       = {{ UI }}.t);

  {{ fqn_liquid_inflow }} InflowCatholyte(
    specRec = {{ UI }}.AESspec,
    GeoRec  = {{ UI }}.GeoRecElec,
    CondRec = {{ UI }}.CondRec,
    c0      = {{ UI }}.c0_Electrolyte,
    t       = {{ UI }}.t);

  // ── Gas inflow ───────────────────────────────────────────────────────────────
  {{ fqn_gas_inflow }} InflowGasChannel(
    specRec = {{ UI }}.AESspec,
    GeoRec  = {{ UI }}.GeoRec,
    CondRec = {{ UI }}.CondRec,
    c0      = {{ UI }}.c0_GasChannel,
    t       = {{ UI }}.t);

  // ── Outflows ─────────────────────────────────────────────────────────────────
  {{ fqn_simple_outflow }} OutflowAnolyte(specRec   = {{ UI }}.AESspec);
  {{ fqn_simple_outflow }} OutflowCatholyte(specRec = {{ UI }}.AESspec);
  {{ fqn_simple_outflow }} OutflowGasChannel(specRec = {{ UI }}.AESspec);

equation
  // Electrical
  connect(Ground.p,              Source.p);
  connect(Anode.p,               Source.n);
  connect(GasDiffusionCathode.n, Source.p);

  // Liquid flow chain: Anode → Anolyte → Diaphragm → Catholyte → GDE
  connect(Anode.n,     Anolyte.p);
  connect(Anolyte.n,   Diaphragm.p);
  connect(Diaphragm.n, Catholyte.p);
  connect(Catholyte.n, GasDiffusionCathode.p);

  // Separator material exchange
  connect(Anolyte.rightFlow,  Diaphragm.anCon);
  connect(Diaphragm.catCon,   Catholyte.leftFlow);

  // GDE connections
  connect(Catholyte.rightFlow,              GasDiffusionCathode.flowFromElectrolyte);
  connect(GasDiffusionCathode.flowFromGas,  GasChannel.flowFromElectrode);

  // Anode material flow
  connect(Anode.flowFromElectrolyte, Anolyte.leftFlow);

  // Inflows
  connect(InflowAnolyte.convFlow,    Anolyte.inFlow);
  connect(InflowCatholyte.convFlow,  Catholyte.inFlow);
  connect(InflowGasChannel.convFlow, GasChannel.flowIn);

  // Outflows
  connect(Anolyte.outFlow,    OutflowAnolyte.convFlow);
  connect(Catholyte.outFlow,  OutflowCatholyte.convFlow);
  connect(GasChannel.flowOut, OutflowGasChannel.convFlow);

  annotation(experiment(StopTime = {{ sim_stop_time | monum }}));

{% else %}
  // Electrical ground and voltage source
  {{ fqn_ground }} Ground;

{% if is_batch %}
  {{ fqn_voltage_source }} Source(
    Ufixed = Ufixed,
    GeoRec = {{ UI }}.GeoRec,
    Y = 1,
    Z = 1);
{% else %}
  {{ fqn_voltage_source }} Source(
    Ufixed = Ufixed,
    GeoRec = {{ UI }}.GeoRec);
{% endif %}

  // Electrodes
  {{ fqn_electrode }} Anode(
    specRec   = {{ UI }}.AWEspec,
    GeoRec    = {{ UI }}.GeoRec,
    CondRec   = {{ UI }}.CondRec,
    reac      = {{ "{" + UI + "." + anode_reaction + "}" }},
    CathodeEl = false,
    P         = 100000,
    Pi(each displayUnit="bar"),
    redeclare model ActivationOverpotentialModel = {{ fqn_activation_overpotential }},
    redeclare model TemperatureModel = Properties.TemperatureModels.TemperatureConstant);

  {{ fqn_electrode }} Cathode(
    specRec   = {{ UI }}.AWEspec,
    GeoRec    = {{ UI }}.GeoRec,
    CondRec   = {{ UI }}.CondRec,
    reac      = {{ "{" + UI + "." + cathode_reaction + "}" }},
    CathodeEl = true,
    P         = 100000,
    Pi(each displayUnit="bar"),
    redeclare model ActivationOverpotentialModel = {{ fqn_activation_overpotential }},
    redeclare model TemperatureModel = Properties.TemperatureModels.TemperatureConstant);

  // Electrolyte compartment(s)
{% if is_batch %}
  {{ fqn_electrolyte }} Electrolyte(
    specRec = {{ UI }}.AWEspec,
    GeoRec  = {{ UI }}.GeoRec,
    CondRec = {{ UI }}.CondRec,
    c0      = {{ UI }}.c0,
    X       = {{ geo_X | monum }},
    Y       = {{ geo_Y | monum }},
    Z       = {{ geo_Z | monum }},
{% if use_koh_conductivity %}
    redeclare model ConductivityModel = {{ fqn_koh_conductivity }},
{% endif %}
    redeclare model TemperatureModel = Properties.TemperatureModels.TemperatureConstant);

{% elif use_koh_conductivity %}
  {{ fqn_electrolyte }} Anolyte(
    specRec   = {{ UI }}.AWEspec,
    GeoRec    = {{ UI }}.GeoRec,
    CondRec   = {{ UI }}.CondRec,
    c0        = {{ UI }}.c0,
    redeclare model ConductivityModel = {{ fqn_koh_conductivity }},
    redeclare model TemperatureModel  = Properties.TemperatureModels.TemperatureConstant);

  {{ fqn_electrolyte }} Catholyte(
    specRec   = {{ UI }}.AWEspec,
    GeoRec    = {{ UI }}.GeoRec,
    CondRec   = {{ UI }}.CondRec,
    c0        = {{ UI }}.c0,
    redeclare model ConductivityModel = {{ fqn_koh_conductivity }},
    redeclare model TemperatureModel  = Properties.TemperatureModels.TemperatureConstant);

{% else %}
  {{ fqn_electrolyte }} Anolyte(
    specRec     = {{ UI }}.AWEspec,
    GeoRec      = {{ UI }}.GeoRec,
    CondRec     = {{ UI }}.CondRec,
    c0          = {{ UI }}.c0,
    kappa_const = {{ kappa_anode | monum }},
    redeclare model TemperatureModel = Properties.TemperatureModels.TemperatureConstant);

  {{ fqn_electrolyte }} Catholyte(
    specRec     = {{ UI }}.AWEspec,
    GeoRec      = {{ UI }}.GeoRec,
    CondRec     = {{ UI }}.CondRec,
    c0          = {{ UI }}.c0,
    kappa_const = {{ kappa_cathode | monum }},
    redeclare model TemperatureModel = Properties.TemperatureModels.TemperatureConstant);

{% endif %}
{% if not is_batch %}
  // Separator
  {{ fqn_separator }} Diaphragm(
    specRec = {{ UI }}.AWEspec,
    GeoRec  = {{ UI }}.GeoRec,
    CondRec = {{ UI }}.CondRec,
    kappa   = {{ diaphragm_kappa | monum }},
    X       = {{ diaphragm_X | monum }},
    redeclare model TemperatureModel = Properties.TemperatureModels.TemperatureConstant);

  // Anode-side material flows
  {{ fqn_inflow }} AnodeInflow(
    specRec     = {{ UI }}.AWEspec,
    molFlow_vec = {{ UI }}.c0 * {{ inflow_scale | monum }});

  {{ fqn_connecting_flow }} Flow_anode(
    specRec = {{ UI }}.AWEspec);

  {{ fqn_environment }} env_anode(
    specRec = {{ UI }}.AWEspec);

  // Cathode-side material flows
  {{ fqn_inflow }} CathodeInflow(
    specRec     = {{ UI }}.AWEspec,
    molFlow_vec = {{ UI }}.c0 * {{ inflow_scale | monum }});

  {{ fqn_connecting_flow }} Flow_Cathode(
    specRec = {{ UI }}.AWEspec);

  {{ fqn_environment }} env_cathode(
    specRec = {{ UI }}.AWEspec);

{% endif %}
equation
  // Electrical
  connect(Ground.p,  Source.p);
  connect(Anode.p,   Source.n);
  connect(Source.p,  Cathode.n);

{% if is_batch %}
  // Single shared electrolyte — electrode coupling
  connect(Anode.n,                    Electrolyte.p);
  connect(Electrolyte.n,              Cathode.p);
  connect(Cathode.flowFromElectrolyte, Electrolyte.rightFlow);
  connect(Electrolyte.leftFlow,        Anode.flowFromElectrolyte);

{% else %}
  // Anode side — material flow
  connect(AnodeInflow.convFlow,   Anolyte.inFlow);
  connect(Anolyte.outFlow,        Flow_anode.convinFlow);
  connect(Flow_anode.convoutFlow, env_anode.convFlow);
  // Anode side — electrode coupling and separator
  connect(Anolyte.leftFlow,  Anode.flowFromElectrolyte);
  connect(Anode.n,           Anolyte.p);
  connect(Anolyte.rightFlow, Diaphragm.anCon);
  connect(Anolyte.n,         Diaphragm.p);

  // Cathode side — material flow
  connect(CathodeInflow.convFlow,    Catholyte.inFlow);
  connect(Catholyte.outFlow,         Flow_Cathode.convinFlow);
  connect(Flow_Cathode.convoutFlow,  env_cathode.convFlow);
  // Cathode side — electrode coupling and separator
  connect(Catholyte.rightFlow, Cathode.flowFromElectrolyte);
{% if use_koh_conductivity %}
  connect(Cathode.p,          Catholyte.n);
  connect(Catholyte.leftFlow, Diaphragm.catCon);
  connect(Catholyte.p,        Diaphragm.n);
{% else %}
  connect(Cathode.n,          Catholyte.p);
  connect(Catholyte.leftFlow, Diaphragm.catCon);
  connect(Catholyte.n,        Diaphragm.n);
{% endif %}
{% endif %}

  annotation(experiment(StopTime = {{ sim_stop_time | monum }}));

{% endif %}
end {{ name }};
